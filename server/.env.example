# Archivo de configuración de entorno
# Copia este archivo como .env y completa los valores reales.
#
#   Windows:  copy .env.example .env
#   Linux/Mac: cp .env.example .env
#
# NUNCA subas el archivo .env a un repositorio público.

# ──────────────────────────────────────────────────────────────
# SEGURIDAD
# ──────────────────────────────────────────────────────────────

# Clave secreta usada para firmar los cupones con HMAC-SHA256.
# IMPORTANTE: cambia este valor por una cadena aleatoria larga antes de usar
# el sistema en producción. Puedes generar una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Si esta clave se filtra, cualquiera podría generar cupones válidos.
COUPON_SECRET_KEY=change-me-in-production-please

# PIN para proteger el panel de administración.
# Puede ser numérico o alfanumérico. Mínimo 4 caracteres; recomendado 6+ en producción.
ADMIN_PIN=1234

# ──────────────────────────────────────────────────────────────
# EMAIL (Gmail SMTP)
# ──────────────────────────────────────────────────────────────

# Dirección de Gmail desde la que se enviarán los emails con los cupones QR.
# Ejemplo: mi_bar@gmail.com
GMAIL_USER=tu_correo@gmail.com

# Contraseña de aplicación de Google (16 caracteres).
# NO es tu contraseña normal de Gmail. Debes generarla en:
#   https://support.google.com/accounts/answer/185833
# Pasos: Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
# Copia los 16 caracteres tal cual (con o sin espacios, ambos formatos funcionan).
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
